# Newsletter Provider API Key (server-side only)
NEWSLETTER_API_KEY=

# Public site URL (used for OG tags, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://glowing-earrings.com

# Inline Editor: GitHub PAT with contents:write permission on the repo (server-side only)
GITHUB_TOKEN=

# Inline Editor: Secret used as (a) password for the ⌘⇧E modal login and
# (b) HMAC key to sign the editor_session cookie. Also works as the legacy
# ?edit=YOUR_SECRET URL parameter. Use a long random string (≥32 chars).
EDITOR_SECRET=
